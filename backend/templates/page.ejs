<!-- Clicktrends SEO Page Fragment -->
<style>
  #ct-seo-page-wrapper { font-family: 'Inter', sans-serif; background-color: #ffffff; color: #111827; }
  #ct-seo-page-wrapper h1, #ct-seo-page-wrapper h2, #ct-seo-page-wrapper h3, #ct-seo-page-wrapper h4, #ct-seo-page-wrapper h5, #ct-seo-page-wrapper h6 { font-family: 'Poppins', sans-serif; color: #000000; }
  #ct-seo-page-wrapper .hero-gradient-bg {
    background: linear-gradient(135deg, #ffffff 0%, #fff7ed 50%, #fafafa 100%);
  }
  #ct-seo-page-wrapper .orange-glow {
    box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.15), 0 4px 24px rgba(249, 115, 22, 0.18);
  }
  #ct-seo-page-wrapper .faq-accordion-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease-out, padding 0.3s ease-out;
  }
  #ct-seo-page-wrapper .faq-accordion-item.active .faq-accordion-content {
    max-height: 300px;
    padding-top: 12px;
    padding-bottom: 16px;
  }
  #ct-seo-page-wrapper .faq-accordion-item.active .faq-chevron {
    transform: rotate(180deg);
  }
  #ct-seo-page-wrapper .timeline-line {
    background: repeating-linear-gradient(to bottom, transparent, transparent 4px, #f97316 4px, #f97316 8px);
  }
  #ct-seo-page-wrapper .mobile-menu { display: none; }
  #ct-seo-page-wrapper .mobile-menu.open { display: block; }
  #ct-seo-page-wrapper .sticky-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
  }
</style>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<script src="https://cdn.tailwindcss.com"></script>
<script>
  tailwind.config = {
    theme: {
      extend: {
        fontFamily: {
          heading: ['Poppins', 'sans-serif'],
          body: ['Inter', 'sans-serif'],
        },
        colors: {
          brand: {
            primary: '#f97316',       /* Orange */
            primaryDark: '#ea6c0a',   /* Darker Orange */
            black: '#000000',         /* Black */
            dark: '#111827',          /* Near Black */
            light: '#f9fafb',         /* White alternate */
            border: '#e5e7eb',
            textMuted: '#4b5563',
          }
        }
      }
    }
  }
</script>

<% if (seo.schemaMarkup) { %>
  <script type="application/ld+json">
    <%- typeof seo.schemaMarkup === 'object' ? JSON.stringify(seo.schemaMarkup) : seo.schemaMarkup %>
  </script>
<% } else { %>
  <!-- Dynamic JSON-LD structured data generated by application layer -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "<%= brandName %>",
      "url": "<%= siteUrl %>",
      "telephone": "<%= phoneNumber %>",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "<%= locations %>",
        "addressCountry": "AU"
      },
      "description": "<%= seo.metaDescription %>"
    }
  </script>
<% } %>

<div id="ct-seo-page-wrapper" class="bg-white text-brand-dark antialiased">

  <!-- ===================== STICKY HEADER ===================== -->
  <header class="sticky-header border-b border-gray-200 shadow-sm">
    <!-- Top utility bar -->
    <div class="bg-brand-black text-white py-2 text-xs font-medium border-b border-neutral-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-end gap-6">
        <a href="tel:<%= phoneNumber.replace(/\s+/g, '') %>" class="flex items-center gap-1.5 hover:text-brand-primary transition-colors">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
          <%= phoneNumber %>
        </a>
        <span class="text-neutral-500">|</span>
        <span class="flex items-center gap-1.5 text-neutral-300">
          📍 <%= locations %>
        </span>
      </div>
    </div>

    <!-- Main Navigation Bar -->
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-20">
        <!-- Logo -->
        <a href="<%= siteUrl %>" class="flex items-center gap-2 flex-shrink-0">
          <% if (typeof logoUrl !== 'undefined' && logoUrl && logoUrl !== 'Not available' && logoUrl !== 'text-logo') { %>
            <img src="<%= logoUrl %>" alt="<%= brandName %> Logo" class="h-10 w-auto object-contain" />
          <% } else { %>
            <img src="https://trdemo.com.au/testdomain1/wp-content/uploads/2026/06/Click_trends_logo.png" alt="<%= brandName %> Logo" class="h-10 w-auto object-contain" />
          <% } %>
        </a>

        <!-- Desktop Navigation Links -->
        <div class="hidden md:flex items-center gap-8 relative">
          <a href="<%= siteUrl.replace(/\/$/, '') %>/" class="text-sm font-semibold text-brand-black hover:text-brand-primary transition-colors">Home</a>
          <a href="<%= siteUrl.replace(/\/$/, '') %>/about" class="text-sm font-semibold text-brand-black hover:text-brand-primary transition-colors">About</a>
          
          <!-- Services Dropdown -->
          <div class="group relative">
            <a href="<%= siteUrl.replace(/\/$/, '') %>/services" class="text-sm font-semibold text-brand-primary border-b-2 border-brand-primary pb-1 inline-flex items-center gap-1">
              Services
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </a>
            <!-- Dropdown Menu -->
            <div class="absolute left-0 top-full mt-2 w-64 bg-white border border-gray-100 rounded-xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
              <div class="p-3 space-y-1">
                <% if (typeof allServices !== 'undefined' && allServices.length > 0) { %>
                  <% allServices.forEach(function(service) { %>
                    <div class="mb-2">
                      <div class="px-3 py-1.5 text-[10px] font-bold text-neutral-400 uppercase tracking-wider"><%= service.serviceName %></div>
                      <% (service.subServices || []).forEach(function(sub) { %>
                        <a href="<%= siteUrl.replace(/\/$/, '') %>/<%= sub.pageSlug || sub.subServiceName.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '') %>" class="block px-3 py-2 text-sm text-brand-black hover:bg-orange-50 hover:text-brand-primary rounded-lg transition-colors">
                          <%= sub.subServiceName %>
                        </a>
                      <% }); %>
                    </div>
                  <% }); %>
                <% } else { %>
                  <a href="<%= siteUrl.replace(/\/$/, '') %>/services" class="block px-3 py-2 text-sm text-brand-black hover:bg-orange-50 hover:text-brand-primary rounded-lg transition-colors">All Services</a>
                <% } %>
              </div>
            </div>
          </div>
          
          <a href="<%= siteUrl.replace(/\/$/, '') %>/contact" class="text-sm font-semibold text-brand-black hover:text-brand-primary transition-colors">Contact</a>
          <a href="#booking" class="px-5 py-2.5 text-sm font-heading font-bold text-white bg-brand-primary rounded-xl hover:bg-brand-primaryDark transition-all shadow-md orange-glow">
            Free Consultation
          </a>
        </div>

        <!-- Mobile Menu Hamburger -->
        <button id="mobileMenuToggle" class="md:hidden p-2 rounded-lg text-brand-black hover:bg-neutral-100 transition-colors" aria-label="Toggle mobile menu">
          <svg id="hamburgerIcon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          <svg id="closeIcon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>

      <!-- Mobile Menu Links -->
      <div id="mobileMenu" class="md:hidden hidden border-t border-gray-200 py-3 pb-6">
        <div class="flex flex-col gap-2">
          <a href="<%= siteUrl.replace(/\/$/, '') %>/" class="px-4 py-3 text-sm font-semibold text-brand-black hover:bg-neutral-50 rounded-lg">Home</a>
          <a href="<%= siteUrl.replace(/\/$/, '') %>/about" class="px-4 py-3 text-sm font-semibold text-brand-black hover:bg-neutral-50 rounded-lg">About</a>
          
          <div class="px-4 py-3 rounded-lg bg-orange-50/30">
            <a href="<%= siteUrl.replace(/\/$/, '') %>/services" class="text-sm font-semibold text-brand-primary block mb-3">Services</a>
            <div class="pl-4 space-y-3 border-l-2 border-orange-200 ml-2">
              <% if (typeof allServices !== 'undefined' && allServices.length > 0) { %>
                <% allServices.forEach(function(service) { %>
                  <div>
                    <div class="text-[10px] font-bold text-neutral-400 uppercase mb-2"><%= service.serviceName %></div>
                    <div class="space-y-2">
                      <% (service.subServices || []).forEach(function(sub) { %>
                        <a href="<%= siteUrl.replace(/\/$/, '') %>/<%= sub.pageSlug || sub.subServiceName.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '') %>" class="block text-sm text-brand-black hover:text-brand-primary">
                          <%= sub.subServiceName %>
                        </a>
                      <% }); %>
                    </div>
                  </div>
                <% }); %>
              <% } %>
            </div>
          </div>
          
          <a href="<%= siteUrl.replace(/\/$/, '') %>/contact" class="px-4 py-3 text-sm font-semibold text-brand-black hover:bg-neutral-50 rounded-lg">Contact</a>
          <div class="px-4 pt-3">
            <a href="#booking" class="block w-full text-center px-5 py-3.5 text-sm font-heading font-bold text-white bg-brand-primary rounded-xl hover:bg-brand-primaryDark transition-all shadow-md">
              Free Consultation
            </a>
          </div>
        </div>
      </div>
    </nav>
  </header>
  <!-- ===================== END STICKY HEADER ===================== -->


  <!-- ===================== HERO SECTION ===================== -->
  <section class="hero-gradient-bg overflow-hidden relative border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-16 relative z-10">

      <!-- Breadcrumbs -->
      <nav class="flex items-center gap-2 text-xs font-semibold text-brand-textMuted mb-8" aria-label="Breadcrumb">
        <a href="/" class="hover:text-brand-primary transition-colors">Home</a>
        <svg class="w-3 h-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span>Services</span>
        <svg class="w-3 h-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-brand-black"><%= serviceName %></span>
        <svg class="w-3 h-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-brand-primary font-bold"><%= subServiceName %></span>
      </nav>

      <!-- Two-column hero layout -->
      <div class="grid lg:grid-cols-12 gap-12 xl:gap-16 items-center">

        <!-- LEFT COLUMN: Copywriting Text Content -->
        <div class="lg:col-span-7 flex flex-col gap-6">
          <!-- Eyebrow Category Tag -->
          <div class="inline-flex items-center gap-2 self-start">
            <span class="flex items-center gap-2 px-4 py-1.5 rounded-full bg-white border border-brand-primary/30 shadow-sm text-xs font-bold text-brand-black uppercase tracking-wide">
              <span class="w-2.5 h-2.5 rounded-full bg-brand-primary animate-pulse"></span>
              <%= hero.eyebrow || (serviceName + ' Services') %>
            </span>
          </div>

          <!-- H1 Title -->
          <h1 class="font-heading font-black text-3.5xl sm:text-4.5xl xl:text-5xl leading-tight text-brand-black">
            <%= hero.h1Title %>
          </h1>

          <!-- Subheading Text (High Depth) -->
          <p class="font-body text-base sm:text-lg text-brand-textMuted leading-relaxed text-justify max-w-2xl">
            <%= hero.subheading %>
          </p>

          <!-- Action Buttons -->
          <div class="flex flex-col sm:flex-row gap-4 pt-2">
            <a href="#booking" class="inline-flex items-center justify-center gap-2 px-8 py-4 text-sm font-heading font-bold text-white bg-brand-primary rounded-xl shadow-lg hover:bg-brand-primaryDark hover:shadow-xl transition-all orange-glow group">
              <%= cta.buttonText || 'Claim Free Audit' %>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </a>
            <a href="#comparison" class="inline-flex items-center justify-center gap-2 px-8 py-4 text-sm font-heading font-bold text-brand-black bg-white border-2 border-brand-black rounded-xl hover:bg-neutral-50 transition-all">
              Compare Methods
            </a>
          </div>

          <!-- Phone number nudge -->
          <div class="flex items-center gap-2 text-xs text-brand-textMuted mt-1">
            <span class="w-1.5 h-1.5 rounded-full bg-neutral-400"></span>
            Speak directly with an advisor: 
            <a href="tel:<%= phoneNumber.replace(/\s+/g, '') %>" class="text-brand-primary font-bold hover:underline"><%= phoneNumber %></a>
          </div>

          <!-- Trust Badges Strip -->
          <div class="pt-6 border-t border-gray-100 mt-2">
            <p class="text-xs font-bold uppercase tracking-wider text-brand-black mb-3">Guaranteed Quality Indicators:</p>
            <div class="flex flex-wrap gap-2">
              <% (hero.trustBadges || trustIndicators || []).forEach(function(badge) { %>
                <span class="px-3.5 py-1.5 text-xs font-semibold rounded-lg bg-neutral-100 border border-neutral-200 text-brand-black flex items-center gap-1.5 shadow-sm">
                  <span class="w-1.5 h-1.5 rounded-full bg-brand-primary"></span>
                  <%= typeof badge === 'object' ? (badge.value + ' ' + badge.label) : badge %>
                </span>
              <% }); %>
            </div>
          </div>
        </div>

        <!-- RIGHT COLUMN: Responsive CSS Local Pack Dashboard Widget (No SVGs!) -->
        <div class="lg:col-span-5 flex items-center justify-center">
          <div class="relative w-full max-w-md bg-white rounded-2xl shadow-xl border border-gray-200 overflow-hidden">
            <!-- Header bar -->
            <div class="h-12 bg-brand-black flex items-center px-4 gap-2 border-b border-neutral-800">
              <div class="flex gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-neutral-700"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-neutral-700"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-neutral-700"></div>
              </div>
              <div class="flex-1 bg-neutral-900 rounded-lg h-6 flex items-center px-3 text-[10px] text-neutral-400 truncate">
                🔍 Google Maps · <%= subServiceName %> In <%= locations %>
              </div>
            </div>

            <!-- Dashboard Mockup content -->
            <div class="p-5 bg-neutral-50 space-y-4">
              <!-- Search result summary -->
              <div class="bg-white border border-gray-200 rounded-xl p-3.5 shadow-sm flex items-center justify-between">
                <div>
                  <p class="text-[10px] font-bold text-neutral-400 uppercase tracking-widest">Active Search Target</p>
                  <p class="text-xs font-bold text-brand-black mt-0.5"><%= subServiceName %> <%= locations %></p>
                </div>
                <div class="flex items-center gap-1.5 bg-orange-50 px-2 py-1 rounded-full border border-orange-100">
                  <span class="w-2 h-2 rounded-full bg-brand-primary animate-ping"></span>
                  <span class="text-[10px] font-bold text-brand-primary">Rank Tracking Active</span>
                </div>
              </div>

              <!-- Map pack results mockup list -->
              <div class="space-y-2.5">
                <!-- R1 (Your Business) -->
                <div class="bg-white border-2 border-brand-primary rounded-xl p-4 shadow-md relative overflow-hidden transition-all hover:scale-[1.02]">
                  <div class="absolute top-0 right-0 bg-brand-primary text-white text-[9px] font-black uppercase px-2.5 py-1 rounded-bl-lg">
                    ★ #1 Rank
                  </div>
                  <div class="flex gap-3">
                    <div class="w-10 h-10 rounded-lg bg-brand-black flex items-center justify-center flex-shrink-0 text-white font-extrabold text-sm border border-brand-primary">
                      <%= brandName[0] %>
                    </div>
                    <div>
                      <h4 class="text-xs font-bold text-brand-black"><%= brandName %></h4>
                      <p class="text-[10px] text-brand-primary font-bold mt-0.5">5.0 ★★★★★ <span class="text-neutral-400">(184 reviews)</span></p>
                      <p class="text-[9px] text-neutral-500 mt-1">Open · Closes 5:00 PM</p>
                      <p class="text-[9px] text-neutral-500">📞 <%= phoneNumber %></p>
                    </div>
                  </div>
                </div>

                <!-- R2 (Competitor A) -->
                <div class="bg-white border border-gray-200 rounded-xl p-4 shadow-sm opacity-80">
                  <div class="flex gap-3">
                    <div class="w-10 h-10 rounded-lg bg-neutral-200 flex items-center justify-center flex-shrink-0 text-neutral-500 font-bold text-xs">
                      C1
                    </div>
                    <div>
                      <h4 class="text-xs font-bold text-neutral-700">Competitor Business A</h4>
                      <p class="text-[10px] text-neutral-500 mt-0.5">4.2 ★★★★☆ <span class="text-neutral-400">(29 reviews)</span></p>
                      <p class="text-[9px] text-neutral-400 mt-1">Closed · Opens 9:00 AM</p>
                    </div>
                  </div>
                </div>

                <!-- R3 (Competitor B) -->
                <div class="bg-white border border-gray-200 rounded-xl p-4 shadow-sm opacity-60">
                  <div class="flex gap-3">
                    <div class="w-10 h-10 rounded-lg bg-neutral-100 flex items-center justify-center flex-shrink-0 text-neutral-400 font-bold text-xs">
                      C2
                    </div>
                    <div>
                      <h4 class="text-xs font-bold text-neutral-500">Competitor Business B</h4>
                      <p class="text-[10px] text-neutral-400 mt-0.5">3.9 ★★★☆☆ <span class="text-neutral-400">(14 reviews)</span></p>
                      <p class="text-[9px] text-neutral-400 mt-1">Closed · Opens 8:30 AM</p>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Action buttons inside mockup -->
              <div class="flex gap-2.5 pt-1">
                <div class="flex-1 bg-brand-black text-white text-[10px] font-bold text-center py-2.5 rounded-lg border border-neutral-800">
                  Impressions: +245%
                </div>
                <div class="flex-1 bg-brand-primary text-white text-[10px] font-bold text-center py-2.5 rounded-lg">
                  Phone Leads: 3.2x
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>
  <!-- ===================== END HERO SECTION ===================== -->


  <!-- ===================== PAIN POINTS SECTION ===================== -->
  <section class="py-20 bg-neutral-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Section Header (High Depth) -->
      <div class="max-w-3xl mx-auto text-center mb-16">
        <span class="text-brand-primary text-xs font-bold uppercase tracking-widest bg-orange-50 px-3.5 py-1.5 rounded-full border border-orange-100 inline-block mb-4">
          Key Challenges
        </span>
        <h2 class="text-2.5xl sm:text-3.5xl font-black text-brand-black leading-tight tracking-tight">
          <%= problemSection.h2Title %>
        </h2>
        <p class="text-base text-brand-textMuted leading-relaxed text-justify mt-4">
          <%- problemSection.intro.replace(/\n\n/g, '<br/><br/>') %>
        </p>
      </div>

      <!-- Grid Cards (exactly 5 items) -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% (painPoints || []).forEach(function(item, idx) { %>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-200 hover:shadow-md hover:-translate-y-1 transition-all duration-300 flex flex-col <%= idx === 4 ? 'md:col-span-2 lg:col-span-1' : '' %>">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-14 h-14 rounded-xl bg-orange-50 border border-orange-100 flex items-center justify-center text-3xl">
                <%= item.emoji || '⚠️' %>
              </div>
              <div>
                <p class="text-[10px] font-bold text-brand-primary uppercase tracking-wider">Vertical Challenge <%= idx + 1 %></p>
                <h3 class="text-base font-bold text-brand-black leading-snug"><%= item.scenarioTitle %></h3>
              </div>
            </div>
            <div class="w-12 h-1 bg-brand-primary rounded-full mb-6"></div>
            <p class="text-brand-textMuted text-sm leading-relaxed text-justify flex-grow">
              <%= item.description %>
            </p>
          </div>
        <% }); %>
      </div>

      <!-- Action-orientated warning summary -->
      <div class="mt-12 text-center max-w-2xl mx-auto">
        <p class="text-xs font-semibold text-brand-textMuted uppercase tracking-widest">Does your business suffer from these bottlenecks?</p>
        <p class="text-xs text-neutral-400 mt-2">Our systematic, data-led methodology is explicitly engineered to resolve these issues and secure ranking stability.</p>
      </div>

    </div>
  </section>
  <!-- ===================== END PAIN POINTS SECTION ===================== -->


  <!-- ===================== SERVICES METHODOLOGY SECTION ===================== -->
  <section class="py-20 bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Section Header -->
      <div class="max-w-3xl mx-auto text-center mb-16">
        <span class="text-brand-primary text-xs font-bold uppercase tracking-widest bg-orange-50 px-3.5 py-1.5 rounded-full border border-orange-100 inline-block mb-4">
          Core Workstreams
        </span>
        <h2 class="text-2.5xl sm:text-3.5xl font-black text-brand-black leading-tight tracking-tight">
          <%= servicesSectionTitle || ('How Our ' + subServiceName + ' Framework Operates') %>
        </h2>
        <p class="text-base text-brand-textMuted leading-relaxed mt-4">
          Our specialized methodology addresses the core algorithmic variables of search engine indexing to construct compounding organic authority.
        </p>
      </div>

      <!-- Two-column split layout -->
      <div class="grid lg:grid-cols-12 gap-12 xl:gap-16 items-start">
        <!-- LEFT: 8 Workstreams list -->
        <div class="lg:col-span-7 space-y-0 divide-y divide-gray-100 border border-gray-200 rounded-2xl overflow-hidden shadow-sm">
          <% (services || []).forEach(function(item, idx) { %>
            <div class="group bg-white hover:bg-neutral-50 transition-colors p-6 border-l-4 border-l-transparent hover:border-l-brand-primary">
              <div class="flex items-start gap-4">
                <div class="w-8 h-8 rounded-lg bg-orange-50 group-hover:bg-brand-primary text-brand-primary group-hover:text-white flex items-center justify-center font-bold text-sm transition-colors duration-200 flex-shrink-0">
                  <%= idx + 1 %>
                </div>
