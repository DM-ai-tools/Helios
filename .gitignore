# ============================================================
# ClickTrends AI Audit — .gitignore
# ============================================================

# Environment secrets — NEVER commit
.env
.env.local
.env.*.local

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Generated reports & temp files
reports/
*.pdf
*.docx

# Puppeteer browser cache
.cache/

# Redis / Windows-only binaries
redis-windows/
Redis-x64.zip

# Test & debug scripts (not needed in production)
test.pdf
install.log
temp.js

# macOS
.DS_Store

# Windows
Thumbs.db
