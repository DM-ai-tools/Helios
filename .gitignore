# Environment secrets — NEVER commit
.env
.env.local
.env.*.local

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Generated reports & temp files
reports/
*.pdf
*.docx

# Puppeteer browser cache
.cache/

# Redis / Windows-only binaries
redis-windows/
Redis-x64.zip

# Test & debug scripts (not needed in production)
test.pdf
install.log
temp.js

# Dev/debug utility scripts (local only)
clear-pdf-cache.js
check-db.js
check-db.mjs
check-latest.mjs
drop-db.mjs
dump-crawled-data.mjs
fetch-audit-result.mjs
fetch-failed-audit.mjs
print-debug.mjs
show-live-results.mjs
show-redis.mjs
show-results.mjs
test-*.mjs
test-*.cjs
test-*.js
test_crawler.mjs
test_fetch.js
raw-email-output.txt

# macOS
.DS_Store

# Windows
Thumbs.db


wp_diagnostic.js
