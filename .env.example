# ============================================================
# ClickTrends AI Audit — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# Set these as Railway environment variables in the dashboard.
# ============================================================

# ─── Server ──────────────────────────────────────────────────
PORT=3000
CORS_ORIGIN=*

# ─── Anthropic (Claude AI) — one key per plugin for parallel execution ───────
# Each plugin fires simultaneously using its own dedicated API key.
# Get keys at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxx
ANTHROPIC_API_KEY_2=sk-ant-api03-xxx
ANTHROPIC_API_KEY_3=sk-ant-api03-xxx
ANTHROPIC_API_KEY_4=sk-ant-api03-xxx
ANTHROPIC_API_KEY_5=sk-ant-api03-xxx
ANTHROPIC_API_KEY_6=sk-ant-api03-xxx

# ─── OpenRouter (Perplexity web research only) ───────────────
# Used ONLY for Perplexity sonar models — live web search &
# competitive intelligence during the audit crawl phase.
# Get your key at: https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-xxx

# ─── Redis ───────────────────────────────────────────────────
# On Railway: add a Redis service and Railway sets this automatically.
# Format: redis://[password@]host:port[/db-number]
REDIS_URL=redis://127.0.0.1:6379

# ─── Database (PostgreSQL — optional, currently unused) ──────
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ─── Email (Resend) ──────────────────────────────────────────
# Get your key at: https://resend.com/
# Leave blank to use mock/log-only email mode
RESEND_API_KEY=

# ─── OpenAI (PDF report generation) ─────────────────────────
OPENAI_MODEL=gpt-4o-mini
OPEN_AI_APIKEY=sk-proj-xxx

# ─── Optional SMTP fallback ──────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_app_password
